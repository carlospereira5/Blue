# ============================================================
# Lumi — Variables de entorno
# ============================================================
# Estos valores deben cargarse via Infisical (task dev).
# Para desarrollo local sin Infisical, copiá este archivo a .env
# y completá los valores reales. .env está en .gitignore.
# ============================================================

# --- Loyverse ---
LOYVERSE_TOKEN=           # Loyverse Admin > Configuración > API Tokens

# --- LLM Provider ---
PROVIDER=openai           # "openai" (Groq, recomendado) o "gemini"

# Groq — si PROVIDER=openai
OPENAI_API_KEY=           # console.groq.com > API Keys
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Gemini — si PROVIDER=gemini
GEMINI_API_KEY=           # aistudio.google.com > Get API key

# --- WhatsApp ---
WHATSAPP_DB_PATH=whatsapp.db
ALLOWED_NUMBERS=          # CSV en formato E.164: +56912345678,+56987654321
                          # Dejar vacío para correr en modo CLI (sin WhatsApp)
WHATSAPP_GROUP_JID=       # JID del grupo: 120363xxxxxxxx@g.us
                          # Dejar vacío para aceptar mensajes de cualquier chat

# --- App ---
SUPPLIERS_FILE=suppliers.json
DEBUG=false               # "true" para logging verbose del pipeline Groq <-> Loyverse
PORT=8080
ENV=production
