# Loyverse API — get from Loyverse Admin > Settings > API
LOYVERSE_TOKEN=your-loyverse-token

# Gemini API — get from Google AI Studio
GEMINI_API_KEY=your-gemini-api-key

# Supplier aliases JSON file path (default: suppliers.json)
SUPPLIERS_FILE=suppliers.json

# Debug mode — logs all internal agent flow (tool calls, Loyverse responses, etc.)
# Set to "true" to enable verbose logging
DEBUG=false

# Optional
PORT=8080
ENV=development
